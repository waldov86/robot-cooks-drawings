# Gemini API - SERVER SIDE ONLY, never expose to client
GEMINI_API_KEY=

# Supabase - public URL and anon key (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role - SERVER SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Optional: owner ID for single-user mode (UUID)
# In multi-user mode, replace with actual auth
DEFAULT_OWNER_ID=00000000-0000-0000-0000-000000000001
